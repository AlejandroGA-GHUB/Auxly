# Required: your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=paste-your-token-here

# Optional: only needed for Spotify albums/playlists (single track links
# work without these). Create an app at https://developer.spotify.com/dashboard
# and copy these in. Note: Spotify requires a Premium account to create apps.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: per-profile limits. Leave blank for the defaults: 1000 songs
# total across a profile's playlists, and 100 stored audio files within
# that (stored files are real audio on your disk, hence the smaller cap).
PROFILE_SONG_CAP=
PROFILE_FILE_CAP=
